{
  "jest": {
    "verbose": true,
    "collectCoverage": true,
    "coverageDirectory": "<rootDir>/tests/javascript/coverage",
    "collectCoverageFrom": [
      "<rootDir>/static/historic/*.js",
      "!<rootDir>/static/historic/*.min*.js",
      "!<rootDir>/tests/javascript/coverage/**"
    ],
    "coverageReporters": [
      "lcov",
      "text"
    ],
    "setupFiles": [
      "jest-localstorage-mock",
      "<rootDir>/tests/javascript/test_helpers.js"
    ],
    "testEnvironment": "jsdom"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "jest-localstorage-mock": "^2.4.26",
    "jest-environment-jsdom": "^29.7.0",
    "canvas": "^2.5.0",
    "jest": "^29.7.0",
    "mock-socket": "^9.3.1"
  }
}
